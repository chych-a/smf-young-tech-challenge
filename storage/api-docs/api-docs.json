{
    "openapi": "3.0.0",
    "info": {
        "title": "SMF Young Tech Challenge API",
        "description": "REST API dla CRUD produktów oraz uploadu faktur/paragonów z OCR i ekstrakcją AI.",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://localhost:8000",
            "description": "Local development"
        }
    ],
    "paths": {
        "/api/invoices": {
            "get": {
                "tags": [
                    "Invoices"
                ],
                "summary": "Lista przetworzonych dokumentów",
                "operationId": "2e947f49543378e8d1ac24fc3ebcdcc7",
                "responses": {
                    "200": {
                        "description": "OK"
                    }
                }
            }
        },
        "/api/invoices/{invoice}": {
            "get": {
                "tags": [
                    "Invoices"
                ],
                "summary": "Szczegóły dokumentu",
                "operationId": "a81909c52dc527fa7fef63222e1b052e",
                "parameters": [
                    {
                        "name": "invoice",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK"
                    }
                }
            },
            "delete": {
                "tags": [
                    "Invoices"
                ],
                "summary": "Usuń dokument i dane ekstrakcji",
                "operationId": "a60bf154d9b3cb9a2886beff7abba378",
                "parameters": [
                    {
                        "name": "invoice",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "204": {
                        "description": "No Content"
                    }
                }
            },
            "patch": {
                "tags": [
                    "Invoices"
                ],
                "summary": "Ręczna korekta danych po OCR",
                "operationId": "f5b0af1ffe1542dae9fc8deec1cb7d4e",
                "parameters": [
                    {
                        "name": "invoice",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK"
                    }
                }
            }
        },
        "/api/invoices/upload": {
            "post": {
                "tags": [
                    "Invoices"
                ],
                "summary": "Upload PDF/JPG/PNG i ekstrakcja OCR + AI",
                "operationId": "168d7a83d797bcdfc97748805f1603e6",
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {}
                    }
                },
                "responses": {
                    "201": {
                        "description": "Created"
                    }
                }
            }
        },
        "/api/products": {
            "get": {
                "tags": [
                    "Products"
                ],
                "summary": "Lista produktów",
                "operationId": "d97d1c3727cbac49708b85f7d11f7d58",
                "responses": {
                    "200": {
                        "description": "OK"
                    }
                }
            },
            "post": {
                "tags": [
                    "Products"
                ],
                "summary": "Utwórz produkt",
                "operationId": "785644b7d7dd38af4b51dafd0fbc1b6d",
                "responses": {
                    "201": {
                        "description": "Created"
                    }
                }
            }
        },
        "/api/products/{product}": {
            "get": {
                "tags": [
                    "Products"
                ],
                "summary": "Szczegóły produktu",
                "operationId": "db00b523e69d5dbc09c6edad76374bdc",
                "parameters": [
                    {
                        "name": "product",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK"
                    }
                }
            },
            "put": {
                "tags": [
                    "Products"
                ],
                "summary": "Aktualizuj produkt",
                "operationId": "f47cf55f4f3e0b134b5e7d9a8373725d",
                "parameters": [
                    {
                        "name": "product",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK"
                    }
                }
            },
            "delete": {
                "tags": [
                    "Products"
                ],
                "summary": "Usuń produkt",
                "operationId": "ac878db81fdb1333b21fc79e574a5a17",
                "parameters": [
                    {
                        "name": "product",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "204": {
                        "description": "No Content"
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "ProductInput": {
                "required": [
                    "name",
                    "price",
                    "currency",
                    "stock"
                ],
                "properties": {
                    "name": {
                        "type": "string",
                        "example": "Usługa wdrożeniowa"
                    },
                    "sku": {
                        "type": "string",
                        "example": "DEMO-001",
                        "nullable": true
                    },
                    "description": {
                        "type": "string",
                        "nullable": true
                    },
                    "price": {
                        "type": "number",
                        "format": "float",
                        "example": 199
                    },
                    "currency": {
                        "type": "string",
                        "example": "PLN"
                    },
                    "stock": {
                        "type": "integer",
                        "example": 5
                    }
                },
                "type": "object"
            }
        }
    },
    "tags": [
        {
            "name": "Invoices",
            "description": "Upload faktur/paragonów i ekstrakcja danych"
        },
        {
            "name": "Products",
            "description": "CRUD produktów demonstracyjnych"
        }
    ]
}